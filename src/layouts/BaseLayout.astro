---
import '../styles/global.css';
import { site } from '../data/site.js';
import { canonicalFromPath, stripBase, withBase } from '../utils/paths.js';

const {
  title = `${site.name} | Portfolio`,
  description = site.description
} = Astro.props;

const pathname = stripBase(Astro.url.pathname);
const isHome = pathname === '/';
const canonicalUrl = canonicalFromPath(pathname, site.url);
const year = new Date().getFullYear();
const navLinks = isHome
  ? [
      { href: '#work', label: 'Work' },
      { href: withBase('/dashboard'), label: 'Dashboard' },
      { href: '#experience', label: 'Experience' },
      { href: '#about', label: 'About' },
      { href: '#contact', label: 'Contact' }
    ]
  : [
      { href: withBase('/'), label: 'Home' },
      { href: withBase('/#work'), label: 'Projects' },
      { href: withBase('/dashboard'), label: 'Dashboard' },
      { href: '#contact', label: 'Contact' }
    ];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#10141f" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
  </head>
  <body>
    <div class="page-atmosphere" aria-hidden="true"></div>
    <div class="page-grid-overlay" aria-hidden="true"></div>

    <header class="site-header">
      <div class="site-inner">
        <a class="site-brand" href={withBase('/')}>
          <span class="brand-mark">GE</span>
          <span>
            <strong>{site.name}</strong>
            <small>{site.role}</small>
          </span>
        </a>

        <nav class="site-nav" aria-label="Primary">
          {navLinks.map((link) => (
            <a class="nav-link" href={link.href}>
              {link.label}
            </a>
          ))}
          <a class="button-secondary nav-button" href={withBase(site.resume)} target="_blank" rel="noreferrer">
            Resume
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer" id="contact">
      <div class="site-inner footer-inner">
        <div>
          <p class="eyebrow">Built to make technical signal obvious</p>
          <h2 class="footer-title">Interested in backend, platform, automation, or systems-focused roles.</h2>
        </div>

        <div class="footer-actions">
          <a class="button-primary" href={`mailto:${site.email}`}>Email</a>
          <a class="button-secondary" href={site.linkedin} target="_blank" rel="noreferrer">
            LinkedIn
          </a>
          <a class="button-secondary" href={site.github} target="_blank" rel="noreferrer">
            GitHub
          </a>
        </div>

        <div class="footer-meta">
          <p>{site.location}</p>
          <p>AI automation, backend systems, cloud infrastructure</p>
          <p>&copy; {year} {site.name}</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.18 }
          );
          revealItems.forEach((item) => observer.observe(item));
        } else {
          revealItems.forEach((item) => item.classList.add('is-visible'));
        }
      })();
    </script>
  </body>
</html>
