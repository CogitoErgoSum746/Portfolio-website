---
const { eyebrow, title, body, align = 'left' } = Astro.props;
---

<div class:list={['space-y-4 max-w-3xl', align === 'center' && 'mx-auto text-center']} data-reveal>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="section-title">{title}</h2>
  {body && <p class="section-body">{body}</p>}
</div>
